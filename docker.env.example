# Copy to .env.docker and keep that file local. Never commit real credentials.
AI_TRADE_DOCKER_PORT=8877
AI_TRADE_DOCKER_UID=10001
AI_TRADE_DOCKER_GID=10001
TZ=Asia/Shanghai

# Optional Tushare Pro token for an independent daily-bar reference check.
# It never enters strategy snapshots and is not stored by AI Trade.
AI_TRADE_TUSHARE_TOKEN=

# Optional model-enhanced research. Local rules need none of these values.
AI_TRADE_AI_BASE_URL=https://api.openai.com/v1
AI_TRADE_AI_MODEL=
AI_TRADE_AI_API_KEY=
AI_TRADE_AI_TIMEOUT_SECONDS=30
AI_TRADE_AI_MAX_RETRIES=1
AI_TRADE_AI_MAX_CONCURRENT_CALLS=1
AI_TRADE_AI_MAX_TOKENS_PER_CALL=50000
AI_TRADE_AI_DAILY_TOKEN_BUDGET=100000
# Optional provider prices enable estimated USD accounting. Configure both
# rates together. A daily USD budget additionally requires both rates.
AI_TRADE_AI_INPUT_COST_PER_MILLION_USD=
AI_TRADE_AI_OUTPUT_COST_PER_MILLION_USD=
AI_TRADE_AI_DAILY_COST_BUDGET_USD=

# Optional monitoring webhook. HTTPS is required for external hosts; HTTP is
# accepted only for loopback integration endpoints. The secret is never saved.
AI_TRADE_WEBHOOK_URL=
AI_TRADE_WEBHOOK_SECRET=
AI_TRADE_WEBHOOK_TIMEOUT_SECONDS=5
AI_TRADE_WEBHOOK_MAX_ATTEMPTS=3
AI_TRADE_WEBHOOK_RETRY_BASE_SECONDS=0.5
AI_TRADE_WEBHOOK_BATCH_SIZE=50

# Optional SMTP email delivery. Desktop Toast is intentionally host-only.
AI_TRADE_EMAIL_SMTP_HOST=
AI_TRADE_EMAIL_SMTP_PORT=587
AI_TRADE_EMAIL_SECURITY=starttls
AI_TRADE_EMAIL_USERNAME=
AI_TRADE_EMAIL_PASSWORD=
AI_TRADE_EMAIL_FROM=
AI_TRADE_EMAIL_TO=
AI_TRADE_EMAIL_TIMEOUT_SECONDS=10
AI_TRADE_EMAIL_MAX_ATTEMPTS=3
AI_TRADE_EMAIL_BATCH_SIZE=20

# Optional Cloudflare R2 market-cache backup.
AI_TRADE_CLOUD_ENABLED=0
AI_TRADE_CLOUD_PREFIX=ai-trade
AI_TRADE_CLOUD_INSTALLATION_ID=
AI_TRADE_R2_ENDPOINT=
AI_TRADE_R2_REGION=auto
AI_TRADE_R2_BUCKET=
AI_TRADE_R2_ACCESS_KEY_ID=
AI_TRADE_R2_SECRET_ACCESS_KEY=
